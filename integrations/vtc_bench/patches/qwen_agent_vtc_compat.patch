+    def _detect_tool(self, message: Message) -> tuple[bool, str, str, str]:
+        use_tool, tool_name, tool_args, text = super()._detect_tool(message)
+        if use_tool:
+            return use_tool, tool_name, tool_args, text
+
+        text = self._extract_message_text(message)
+        if not text:
+            return False, None, None, ''
+
+        match = re.search(r'✿FUNCTION✿\s*:\s*([^\n]+?)\s*\n\s*✿ARGS✿\s*:\s*(.+)', text, re.DOTALL)
+        if not match:
+            return False, None, None, text
+
+        tool_name = match.group(1).strip()
+        tool_args = match.group(2).strip()
+        tool_args = re.split(r'\n\s*✿(?:RESULT|RETURN)✿\s*:', tool_args, maxsplit=1)[0].strip()
+        return True, tool_name, tool_args, text
+
+    @staticmethod
+    def _extract_message_text(message: Message) -> str:
+        content = message.content
+        if isinstance(content, str):
+            return content
+        if isinstance(content, list):
+            parts = []
+            for item in content:
+                text = getattr(item, 'text', None)
+                if text:
+                    parts.append(text)
+            return '\n'.join(parts)
+        return ''
+
+    def _normalize_tool_call(self, tool_name: str, tool_args: Union[str, dict],
+                             messages: List[Message]) -> tuple[str, Union[str, dict]]:
+        """Map VTC-Bench human tool labels/arg aliases to registered tool schemas."""
+        normalized_name = self._normalize_tool_name(tool_name)
+        normalized_args = self._normalize_tool_args(normalized_name, tool_args, messages)
+        return normalized_name, normalized_args
+
+    def _normalize_tool_name(self, tool_name: str) -> str:
+        if not tool_name:
+            return tool_name
+        if tool_name in self.function_map:
+            return tool_name
+
+        alias_key = re.sub(r'[^a-z0-9]+', ' ', tool_name.lower()).strip()
+        alias_name = VTC_TOOL_NAME_ALIASES.get(alias_key)
+        if alias_name and alias_name in self.function_map:
+            logger.info(f'Normalized VTC tool name {tool_name!r} to {alias_name!r}')
+            return alias_name
+
+        opencv_guess = 'opencv_' + alias_key.replace(' ', '_')
+        if opencv_guess in self.function_map:
+            logger.info(f'Normalized tool name {tool_name!r} to {opencv_guess!r}')
+            return opencv_guess
+        return tool_name
+
+    def _normalize_tool_args(self, tool_name: str, tool_args: Union[str, dict],
+                             messages: List[Message]) -> Union[str, dict]:
+        try:
+            if isinstance(tool_args, str):
+                if not tool_args.strip():
+                    args = {}
+                else:
+                    args = json_loads(tool_args)
+            elif isinstance(tool_args, dict):
+                args = copy.deepcopy(tool_args)
+            else:
+                return tool_args
+        except Exception:
+            return tool_args
+
+        if not isinstance(args, dict):
+            return tool_args
+
+        for alias in IMAGE_ARG_ALIASES:
+            if 'image' not in args and alias in args:
+                args['image'] = args.pop(alias)
+                break
+
+        if 'image' not in args:
+            image_paths = extract_files_from_messages(messages, include_images=True)
+            if image_paths:
+                args['image'] = image_paths[-1]
+
+        self._normalize_region_args(args)
+
+        tool = self.function_map.get(tool_name)
+        needs_param = False
+        if tool and isinstance(tool.parameters, dict):
+            needs_param = 'param' in tool.parameters.get('required', [])
+        if 'param' not in args:
+            param_keys = [key for key in list(args.keys()) if key not in ('image', 'work_dir')]
+            if param_keys:
+                args['param'] = {key: args.pop(key) for key in param_keys}
+            elif needs_param:
+                args['param'] = {}
+
+        if isinstance(args.get('param'), dict):
+            self._normalize_region_args(args['param'])
+
+        return args
+
+    @staticmethod
